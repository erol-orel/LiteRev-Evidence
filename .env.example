# LiteRev-Evidence — environment configuration (EXAMPLE, no real secrets).
#
# main.py auto-loads, in order (first value wins, never overrides an existing var):
#   ./.env  ·  /opt/literev-api/.env  ·  /etc/literev/env
#   /etc/literev/secrets  ·  /opt/literev-api/secrets.env   (← put SECRETS here)
#
# Copy the lines you need into /opt/literev-api/secrets.env (secrets) or
# /opt/literev-api/.env (non-secret config), then: sudo systemctl restart literev-api
# These files are gitignored — NEVER commit a real key.

# ── Required ────────────────────────────────────────────────────────────────
DB_URL=postgresql+psycopg://user:pass@host:5432/dbname
WRITE_API_KEY=change-me                 # admin key for write endpoints

# ── API keys (all optional; each unlocks/upgrades a source) ─────────────────
OPENAI_API_KEY=                         # semantic scoring + NL→boolean translation
CORE_API_KEY=                           # CORE literature source (free key). Without it CORE is skipped.
NCBI_API_KEY=                           # PubMed: 10 req/s instead of 3 (faster PubMed trio)
SEMANTIC_SCHOLAR_API_KEY=               # Semantic Scholar: higher rate limit (still capped at 1000/query by the API)

# ── Fetch limits (raise to "remove" the caps; see docs/SOURCE_LIMITS.md) ─────
# Per-source fetch ceiling. Set very high (e.g. 100000) to effectively remove it;
# the real governor then becomes the time budget below. ⚠ multiplies API calls
# (429 risk) and OpenAI embedding cost on EVERY search.
LIVE_MAX_PER_SOURCE=2000
# Wall-clock budget (seconds) for the parallel source federation per search. Populate
# runs in a background thread, so raising this doesn't block the request — it just lets
# slow sources paginate longer. e.g. 600 or 1800 for a fuller corpus. Not unbounded on
# purpose (a stuck source would keep the job alive forever).
POPULATE_FEDERATION_BUDGET=180

# ── Optional data-connector overrides ───────────────────────────────────────
# FOPH_WASTEWATER_CSV_URL=              # pin the FOPH wastewater CSV directly
# MODEL_DATA_DIR=/opt/literev-api/uploads_datasets
